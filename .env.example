# 复制为 .env 后填写真实值；.env 勿提交 Git
# cp .env.example .env

# 对外暴露的前端端口（Nginx）
WEB_PORT=8080

# Docker 镜像（Docker Hub: https://hub.docker.com/u/ace11133）
IMAGE_TAG=latest
API_IMAGE=ace11133/grammar-station-api:latest
WEB_IMAGE=ace11133/grammar-station-web:latest

# ---------- API 密钥（仅写在 .env，不要写进本模板并提交）----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# 可选：译文专用更快模型，留空则与 OPENAI_MODEL 相同
# OPENAI_MODEL_TRANSLATION=meta/llama-3.1-8b-instruct
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2048
OPENAI_MAX_TOKENS_TRANSLATION=512
OPENAI_HTTP_READ_TIMEOUT=600
OPENAI_HTTP_CONNECT_TIMEOUT=30

# CORS：生产同域部署可留空；开发多端口时逗号分隔，例 http://localhost:5173
# CORS_ORIGINS=
