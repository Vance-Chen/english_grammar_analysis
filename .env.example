# 对外暴露的前端端口（Nginx）
WEB_PORT=8080

# Docker 镜像名（拷贝部署时与 docker save/load 的标签一致）
IMAGE_TAG=latest
API_IMAGE=grammar-station-api:latest
WEB_IMAGE=grammar-station-web:latest

# OpenAI 或兼容 API（留空则后端进入离线模拟模式）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b
OPENAI_TEMPERATURE=0.3
OPENAI_HTTP_READ_TIMEOUT=600
OPENAI_HTTP_CONNECT_TIMEOUT=30
